# ─────────────────────────────────────────────────────────────────────────────
# agent-os — environment variables
# Copy to .env and fill in your values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLMs ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
OLLAMA_HOST=http://localhost:11434          # local Ollama; or GPU node address
OLLAMA_API_BASE=http://localhost:11434
GEMINI_API_KEY=REPLACE_IF_USING_GEMINI    # optional

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
OPS_DB_HOST=127.0.0.1
OPS_DB_PORT=5432
OPS_DB_USER=agent_user

# ── Telegram (orchestrator bot) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_MY_ID=REPLACE_WITH_YOUR_USER_ID       # your numeric Telegram user ID
TELEGRAM_CHANNEL_ID=                           # channel for content publishing (optional)
TELEGRAM_API_ID=REPLACE_IF_USING_MTProto
TELEGRAM_API_HASH=REPLACE_IF_USING_MTProto
TELEGRAM_PHONE=REPLACE_IF_USING_MTProto

# ── Support bot (separate token) ──────────────────────────────────────────────
SUPPORT_BOT_TOKEN=REPLACE_WITH_SUPPORT_BOT_TOKEN

# ── Gmail (email watchdog) ────────────────────────────────────────────────────
GMAIL1_EMAIL=your@gmail.com
GMAIL1_PASSWORD=REPLACE_WITH_APP_PASSWORD     # Google App Password (not account pw)

# ── Task management ───────────────────────────────────────────────────────────
WEEEK_TOKEN=REPLACE_WITH_WEEEK_API_TOKEN
WEEEK_FUNNEL_ID=
WEEEK_STAGE_NEW=
WEEEK_STAGE_CONTACTED=
WEEEK_STAGE_QUALIFIED=
WEEEK_STAGE_PROPOSAL=

# ── Knowledge base ────────────────────────────────────────────────────────────
OBSIDIAN_VAULT=/path/to/your/obsidian/vault

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=REPLACE_IF_USING_LANGFUSE
LANGFUSE_PUBLIC_KEY=REPLACE_IF_USING_LANGFUSE
LANGFUSE_HOST=http://localhost:3000

# ── Dashboard ─────────────────────────────────────────────────────────────────
INFRA_DASH_URL=http://localhost:8099
